# VANTAGE Monitoring Configuration
# Copy to .env.local and fill in your values

# ============================================
# Grafana Admin Credentials
# ============================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_this_secure_password

# ============================================
# Alertmanager Email Configuration
# ============================================
SMTP_HOST=smtp.gmail.com:587
SMTP_FROM=alerts@vantage.live
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password

# Alert Recipients
ALERT_EMAIL=admin@vantage.live
CRITICAL_ALERT_EMAIL=oncall@vantage.live
DB_TEAM_EMAIL=dba@vantage.live
SECURITY_TEAM_EMAIL=security@vantage.live
MEDIA_TEAM_EMAIL=media@vantage.live

# ============================================
# PagerDuty Integration (Optional)
# ============================================
PAGERDUTY_SERVICE_KEY=your-pagerduty-key

# ============================================
# Slack Integration (Optional)
# ============================================
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ============================================
# Microsoft Teams Integration (Optional)
# ============================================
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/YOUR/WEBHOOK/URL

# ============================================
# Security Webhook (Optional)
# ============================================
SECURITY_WEBHOOK_URL=https://your-security-system.com/webhook

# ============================================
# Environment
# ============================================
ENVIRONMENT=development

# ============================================
# Database (for exporters)
# ============================================
POSTGRES_USER=vantage
POSTGRES_PASSWORD=your_secure_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=vantage

# ============================================
# Redis (for exporters)
# ============================================
REDIS_URL=redis://localhost:6379
