# VANTAGE Executive Platform - Production Environment Variables
# Copy this file to .env.production and fill in secure values

# ==================== DATABASE ====================
DATABASE_URL=postgresql://vantage:YOUR_SECURE_PASSWORD@postgres-primary:5432/vantage
DB_PASSWORD=YOUR_SECURE_PASSWORD

# ==================== REDIS ====================
REDIS_URL=redis://:YOUR_REDIS_PASSWORD@redis-primary:6379
REDIS_PASSWORD=YOUR_REDIS_PASSWORD

# ==================== SECURITY ====================
JWT_SECRET=generate-a-secure-64-character-random-string-here
ENCRYPTION_KEY=generate-a-32-character-hex-string-here

# ==================== TURN SERVER ====================
TURN_SERVER_URL=turn:vantage.live:3478
TURN_SERVER_USERNAME=vantage
TURN_PASSWORD=YOUR_TURN_PASSWORD

# ==================== GRAFANA ====================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=YOUR_GRAFANA_PASSWORD
GRAFANA_URL=https://monitoring.vantage.live

# ==================== SERVER ====================
NODE_ENV=production
PORT=4000
PUBLIC_IP=YOUR_SERVER_PUBLIC_IP

# ==================== SSL/TLS ====================
SSL_CERT_PATH=/etc/ssl/certs/vantage.crt
SSL_KEY_PATH=/etc/ssl/private/vantage.key

# ==================== BACKUP ====================
BACKUP_DIR=/var/backups/vantage
RETENTION_DAYS=30

# ==================== MONITORING ====================
ENABLE_MONITORING=true
METRICS_PORT=9090
