// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER & AUTHENTICATION
// ============================================

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  passwordHash      String
  name              String
  avatarUrl         String?
  role              Role      @default(USER)
  emailVerified     Boolean   @default(false)
  mfaEnabled        Boolean   @default(false)
  mfaSecret         String?
  mfaBackupCodes    Json?
  refreshToken      String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  lastLoginAt       DateTime?
  organizationId    String?

  // Relations
  organization      Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  roomsHosted       Room[]
  roomParticipants  RoomParticipant[]
  meetingsHosted    Meeting[]
  participations    Participant[]
  messages          Message[]
  chatMessages      ChatMessage[]
  reactions         Reaction[]
  recordings        Recording[]
  sessions          Session[]
  consentRecords    ConsentRecord[]
  dataExportRequests DataExportRequest[]
  pollVotes         PollVote[]
  questions         Question[]
  podcasts          Podcast[]

  @@index([email])
  @@index([role])
  @@index([organizationId])
}

enum Role {
  ADMIN
  CEO
  EXECUTIVE
  MANAGER
  USER
  GUEST
}

// ============================================
// ORGANIZATION & BILLING
// ============================================

model Organization {
  id                String    @id @default(cuid())
  name              String    @unique
  slug              String    @unique
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  subscriptionTier  SubscriptionTier @default(FREE)
  maxParticipants   Int       @default(100)
  maxRooms          Int       @default(10)
  storageQuota      BigInt    @default(10737418240) // 10GB default
  
  // Relations
  users             User[]
  rooms             Room[]
  subscription      Subscription?
  invoices          Invoice[]
  apiKeys           ApiKey[]
  recordings        Recording[]

  @@index([slug])
  @@index([subscriptionTier])
}

enum SubscriptionTier {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

model Subscription {
  id                String    @id @default(cuid())
  organizationId    String    @unique
  stripeSubscriptionId String?
  stripeCustomerId  String?
  tier              SubscriptionTier @default(FREE)
  status            String    @default("active")
  currentPeriodStart DateTime?
  currentPeriodEnd  DateTime?
  cancelAtPeriodEnd Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([stripeCustomerId])
  @@index([status])
}

model Invoice {
  id                String    @id @default(cuid())
  organizationId    String
  stripeInvoiceId   String?
  invoiceNumber     String    @unique
  amount            Int       // in cents
  status            InvoiceStatus @default(PENDING)
  dueDate           DateTime?
  paidAt            DateTime?
  url               String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([invoiceNumber])
  @@index([status])
}

enum InvoiceStatus {
  PENDING
  PAID
  FAILED
  VOID
}

model ApiKey {
  id                String    @id @default(cuid())
  organizationId    String
  name              String
  keyHash           String    @unique
  lastUsedAt        DateTime?
  expiresAt         DateTime?
  createdAt         DateTime  @default(now())

  // Relations
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([keyHash])
}

model UsageMetrics {
  id                String    @id @default(cuid())
  organizationId    String
  period            DateTime  // First day of the billing period
  roomsCreated      Int       @default(0)
  messagesSent      Int       @default(0)
  storageUsed       BigInt    @default(0)
  bandwidthUsed     BigInt    @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([organizationId])
  @@index([period])
  @@unique([organizationId, period])
}

// ============================================
// ROOMS (Legacy name for Meetings)
// ============================================

model Room {
  id                String    @id @default(cuid())
  code              String    @unique
  name              String
  hostId            String
  organizationId    String?
  status            RoomStatus @default(SCHEDULED)
  maxParticipants   Int       @default(100)
  password          String?
  allowChat         Boolean   @default(true)
  allowScreenShare  Boolean   @default(true)
  allowRecording    Boolean   @default(true)
  enableWaitingRoom Boolean   @default(false)
  startedAt         DateTime?
  endedAt           DateTime?
  duration          Int?      // in minutes
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  host              User      @relation(fields: [hostId], references: [id], onDelete: Cascade)
  organization      Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  participants      RoomParticipant[]
  messages          ChatMessage[]
  recordings        Recording[]
  reactions         Reaction[]
  polls             Poll[]
  questions         Question[]
  analytics         RoomAnalytics?

  @@index([code])
  @@index([hostId])
  @@index([status])
}

enum RoomStatus {
  SCHEDULED
  ACTIVE
  ENDED
}

model RoomParticipant {
  id                String    @id @default(cuid())
  roomId            String
  userId            String?
  name              String
  role              RoomRole  @default(PARTICIPANT)
  joinedAt          DateTime  @default(now())
  leftAt            DateTime?
  isSpeaking        Boolean   @default(false)
  isHandRaised      Boolean   @default(false)
  isMuted           Boolean   @default(false)
  isVideoOff        Boolean   @default(false)

  // Relations
  room              Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user              User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([roomId])
  @@index([userId])
}

enum RoomRole {
  HOST
  CO_HOST
  PRESENTER
  PARTICIPANT
  VIEWER
}

model RoomAnalytics {
  id                String    @id @default(cuid())
  roomId            String    @unique
  totalParticipants Int       @default(0)
  totalDuration     Int       @default(0) // in seconds
  totalMessages     Int       @default(0)
  totalReactions    Int       @default(0)
  peakParticipants  Int       @default(0)
  lastUpdatedAt     DateTime  @updatedAt

  // Relations
  room              Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId])
}

// ============================================
// MEETINGS (Alias for Rooms - for backward compatibility)
// ============================================

model Meeting {
  id                String    @id @default(cuid())
  code              String    @unique
  name              String
  hostId            String
  hostName          String?
  status            MeetingStatus @default(SCHEDULED)
  maxParticipants   Int       @default(100)
  password          String?
  allowChat         Boolean   @default(true)
  allowScreenShare  Boolean   @default(true)
  allowRecording    Boolean   @default(true)
  enableWaitingRoom Boolean   @default(false)
  scheduledAt       DateTime?
  duration          Int?      // in minutes
  startedAt         DateTime?
  endedAt           DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  host              User      @relation(fields: [hostId], references: [id], onDelete: Cascade)
  participants      Participant[]
  messages          Message[]
  recordings        Recording[]
  reactions         Reaction[]

  @@index([code])
  @@index([hostId])
  @@index([status])
  @@index([scheduledAt])
}

enum MeetingStatus {
  SCHEDULED
  ACTIVE
  ENDED
}

model Participant {
  id                String    @id @default(cuid())
  meetingId         String
  userId            String?
  name              String
  role              ParticipantRole @default(PARTICIPANT)
  joinedAt          DateTime  @default(now())
  leftAt            DateTime?
  isSpeaking        Boolean   @default(false)
  isHandRaised      Boolean   @default(false)
  isMuted           Boolean   @default(false)
  isVideoOff        Boolean   @default(false)

  // Relations
  meeting           Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user              User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  reactions         Reaction[]

  @@index([meetingId])
  @@index([userId])
}

enum ParticipantRole {
  HOST
  CO_HOST
  PRESENTER
  PARTICIPANT
  VIEWER
}

// ============================================
// CHAT MESSAGES
// ============================================

model ChatMessage {
  id                String    @id @default(cuid())
  roomId            String
  userId            String?
  guestName         String?
  content           String
  type              MessageType @default(TEXT)
  parentId          String?
  createdAt         DateTime  @default(now())

  // Relations
  room              Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user              User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  parent            ChatMessage? @relation("MessageReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies           ChatMessage[] @relation("MessageReplies")

  @@index([roomId])
  @@index([userId])
  @@index([createdAt])
}

model Message {
  id                String    @id @default(cuid())
  meetingId         String
  senderId          String
  content           String
  messageType       MessageType @default(TEXT)
  isBroadcast       Boolean   @default(false)
  receiverId        String?
  read              Boolean   @default(false)
  createdAt         DateTime  @default(now())

  // Relations
  meeting           Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  sender            User      @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([meetingId])
  @@index([senderId])
  @@index([createdAt])
}

enum MessageType {
  TEXT
  FILE
  SYSTEM
  EMOJI
  IMAGE
}

// ============================================
// REACTIONS
// ============================================

model Reaction {
  id                String    @id @default(cuid())
  roomId            String?
  meetingId         String?
  userId            String
  participantId     String?
  type              String    // 👍, 👎, 😂, 😮, 😢, 🎉, etc.
  createdAt         DateTime  @default(now())
  expiresAt         DateTime?

  // Relations
  room              Room?     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  meeting           Meeting?  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  participant       Participant? @relation(fields: [participantId], references: [id], onDelete: SetNull)

  @@index([roomId])
  @@index([meetingId])
  @@index([userId])
  @@index([createdAt])
}

// ============================================
// RECORDINGS
// ============================================

model Recording {
  id                String    @id @default(cuid())
  roomId            String?
  meetingId         String?
  userId            String
  organizationId    String?
  title             String
  description       String?
  url               String
  thumbnailUrl      String?
  duration          Int       // in seconds
  size              Int       // in bytes
  format            String    @default("mp4")
  status            RecordingStatus @default(PROCESSING)
  isPublic          Boolean   @default(false)
  downloadCount     Int       @default(0)
  viewCount         Int       @default(0)
  createdAt         DateTime  @default(now())
  processedAt       DateTime?

  // Relations
  room              Room?     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  meeting           Meeting?  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization      Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([roomId])
  @@index([meetingId])
  @@index([userId])
  @@index([status])
  @@index([organizationId])
}

enum RecordingStatus {
  PROCESSING
  READY
  FAILED
  DELETED
}

// ============================================
// ENGAGEMENT (Polls & Questions)
// ============================================

model Poll {
  id                String    @id @default(cuid())
  roomId            String
  title             String
  options           Json      // Array of strings
  status            PollStatus @default(ACTIVE)
  allowMultiple     Boolean   @default(false)
  endsAt            DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  room              Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  votes             PollVote[]

  @@index([roomId])
  @@index([status])
}

enum PollStatus {
  ACTIVE
  ENDED
  HIDDEN
}

model PollVote {
  id                String    @id @default(cuid())
  pollId            String
  userId            String?
  optionIndex       Int
  createdAt         DateTime  @default(now())

  // Relations
  poll              Poll      @relation(fields: [pollId], references: [id], onDelete: Cascade)
  user              User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([pollId])
  @@index([userId])
  @@unique([pollId, userId])
}

model Question {
  id                String    @id @default(cuid())
  roomId            String
  userId            String?
  content           String
  isAnswered        Boolean   @default(false)
  upvotes           Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  room              Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user              User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([roomId])
  @@index([isAnswered])
  @@index([createdAt])
}

// ============================================
// SESSIONS
// ============================================

model Session {
  id                String    @id @default(cuid())
  userId            String
  tokenHash         String    @unique
  refreshToken      String    @unique
  refreshTokenHash  String    @unique
  userAgent         String?
  ipAddress         String?
  expiresAt         DateTime
  createdAt         DateTime  @default(now())

  // Relations
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// ============================================
// GDPR & COMPLIANCE
// ============================================

model DataExportRequest {
  id                String    @id @default(cuid())
  userId            String
  status            DataExportStatus @default(PENDING)
  exportUrl         String?
  expiresAt         DateTime?
  createdAt         DateTime  @default(now())
  completedAt       DateTime?

  // Relations
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

enum DataExportStatus {
  PENDING
  PROCESSING
  READY
  FAILED
  EXPIRED
}

model ConsentRecord {
  id                String    @id @default(cuid())
  userId            String
  consentType       String
  granted           Boolean   @default(true)
  withdrawnAt       DateTime?
  ipAddress         String?
  userAgent         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([consentType])
}

// ============================================
// ANALYTICS & METRICS
// ============================================

model AnalyticsEvent {
  id                String    @id @default(cuid())
  eventType         String
  userId            String?
  meetingId         String?
  roomId            String?
  metadata          Json?
  createdAt         DateTime  @default(now())

  @@index([eventType])
  @@index([userId])
  @@index([meetingId])
  @@index([roomId])
  @@index([createdAt])
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id                String    @id @default(cuid())
  userId            String
  type              NotificationType
  title             String
  message           String
  meetingId         String?
  isRead            Boolean   @default(false)
  createdAt         DateTime  @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

enum NotificationType {
  MEETING_STARTING
  PARTICIPANT_JOINED
  PARTICIPANT_LEFT
  RECORDING_READY
  MESSAGE_RECEIVED
  INVITATION
}

// ============================================
// PODCASTS
// ============================================

model Podcast {
  id                String    @id @default(cuid())
  userId            String
  title             String
  description       String?
  coverImageUrl     String?
  isPublished       Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  episodes          Episode[]

  @@index([userId])
  @@index([isPublished])
}

model Episode {
  id                String    @id @default(cuid())
  podcastId         String
  title             String
  description       String?
  audioUrl          String?
  videoUrl          String?
  duration          Int?      // in seconds
  episodeNumber     Int
  seasonNumber      Int       @default(1)
  isPublished       Boolean   @default(false)
  publishedAt       DateTime?
  viewCount         Int       @default(0)
  likeCount         Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  podcast           Podcast   @relation(fields: [podcastId], references: [id], onDelete: Cascade)

  @@index([podcastId])
  @@index([isPublished])
  @@index([episodeNumber])
}
