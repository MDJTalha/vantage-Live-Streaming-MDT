    "@types/speakeasy": "^2.0.10",
    "concurrently": "^8.2.2",
    "prettier": "^3.2.0",
    "prisma": "^5.22.0",
    "turbo": "^2.0.0",
    "typescript": "^5.3.0",
    "wait-on": "^7.2.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@10.2.0",
