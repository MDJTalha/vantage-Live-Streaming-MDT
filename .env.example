# VANTAGE Environment Configuration
# IMPORTANT: Copy this file to .env.local and fill in your values
# NEVER commit real credentials to version control
# For production, use a secure secrets manager (AWS Secrets Manager, HashiCorp Vault, etc.)

# ============================================
# Environment
# ============================================
NODE_ENV=development
APP_ENV=development

# ============================================
# Database (REQUIRED)
# ============================================
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://vantage:your_secure_password_here@localhost:5432/vantage?schema=public

# ============================================
# Redis (REQUIRED)
# ============================================
# Format: redis://:password@host:port
REDIS_URL=redis://:your_secure_redis_password_here@localhost:6379
REDIS_PASSWORD=your_secure_redis_password_here

# ============================================
# Authentication (REQUIRED FOR PRODUCTION)
# ============================================
# Generate strong keys: openssl rand -base64 32
JWT_SECRET=generate_a_strong_random_secret_key_32_chars_minimum
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# Data encryption key: must be 32 bytes (64 hex chars)
ENCRYPTION_KEY=your_32_byte_encryption_key_here_must_be_exact_length

# ============================================
# OAuth Providers (Optional for dev)
# ============================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/oauth/google/callback

MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_CALLBACK_URL=http://localhost:4000/api/v1/auth/oauth/microsoft/callback

# ============================================
# WebRTC Configuration (REQUIRED FOR PRODUCTION)
# ============================================
TURN_SERVER_URL=turn:your-turn-server:3478
TURN_SERVER_USERNAME=your_turn_username
TURN_SERVER_PASSWORD=your_secure_turn_password
STUN_SERVER=stun:stun.l.google.com:19302

# ============================================
# Media Server Configuration
# ============================================
MEDIA_SERVER_HOST=0.0.0.0
MEDIA_SERVER_PORT=443
MEDIA_SERVER_MIN_PORT=10000
MEDIA_SERVER_MAX_PORT=60000
SSL_KEY_PATH=/etc/certs/key.pem
SSL_CERT_PATH=/etc/certs/cert.pem

# ============================================
# Storage (AWS S3 or compatible)
# ============================================
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET=vantage-recordings

# ============================================
# AI Services
# ============================================
OPENAI_API_KEY=sk-your-openai-api-key
WHISPER_MODEL=base

# ============================================
# Email Configuration
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password

# ============================================
# API Configuration
# ============================================
API_HOST=0.0.0.0
API_PORT=4000
WS_PORT=4000
FRONTEND_URL=http://localhost:3000

# ============================================
# Security Configuration
# ============================================
# Rate limiting: requests per window
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# Storage (S3 Compatible)
# ============================================
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
S3_BUCKET=vantage-recordings

# ============================================
# AI Services
# ============================================
OPENAI_API_KEY=your-openai-api-key
WHISPER_MODEL=base

# ============================================
# External APIs
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-email-password

# ============================================
# Application
# ============================================
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:4000
WS_URL=ws://localhost:4000

# ============================================
# Security
# ============================================
ENCRYPTION_KEY=your-32-character-encryption-key-here-change-this
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

# ============================================
# Monitoring & Observability
# ============================================
# Sentry Error Tracking
SENTRY_DSN=https://your-sentry-key@sentry.io/project-id
SENTRY_ENVIRONMENT=development

# Prometheus Metrics
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# Grafana Dashboards
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_this_password_in_production
GRAFANA_URL=http://localhost:3001

# Datadog (Alternative to Prometheus)
DATADOG_API_KEY=your-datadog-api-key
DATADOG_APP_KEY=your-datadog-app-key
DATADOG_ENV=development

# Alertmanager
ALERT_EMAIL=admin@vantage.live
