{
  "vercel": {
    "project": "vantage-live-streaming-mdt-web",
    "settings": {
      "framework": "nextjs",
      "rootDirectory": "apps/web",
      "buildCommand": "cd ../.. && npm ci --legacy-peer-deps && npx turbo run build --filter=web... --no-cache",
      "installCommand": "cd ../.. && npm ci --legacy-peer-deps",
      "outputDirectory": ".next",
      "git": {
        "deploymentEnabled": {
          "main": true
        }
      }
    },
    "env": {
      "NEXT_PUBLIC_APP_NAME": "VANTAGE",
      "NEXT_PUBLIC_APP_URL": "https://vantage.aivon.site",
      "NEXT_PUBLIC_API_URL": "https://your-api-domain.com",
      "NEXT_PUBLIC_WS_URL": "wss://your-api-domain.com",
      "NODE_ENV": "production"
    }
  }
}
