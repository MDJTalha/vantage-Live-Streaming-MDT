{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm ci --legacy-peer-deps && npx turbo run build --filter=web...",
  "installCommand": "npm ci --legacy-peer-deps",
  "outputDirectory": "apps/web/.next",
  "framework": "nextjs",
  "regions": ["iad1"],
  "env": {
    "NEXT_PUBLIC_APP_NAME": "VANTAGE"
  },
  "git": {
    "deploymentEnabled": {
      "main": true,
      "develop": true
    }
  }
}
