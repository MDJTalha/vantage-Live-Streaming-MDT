{
  "name": "vantage-desktop",
  "version": "1.0.0",
  "description": "VANTAGE Desktop Application for Windows, macOS, and Linux",
  "main": "dist/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "cd ../web && npm run dev",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "cd ../web && npm run build",
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux",
    "dist": "electron-builder",
    "clean": "rm -rf dist"
  },
  "build": {
    "appId": "live.vantage.desktop",
    "productName": "VANTAGE",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "../web/out/**/*"
    ],
    "win": {
      "target": ["nsis", "portable"],
      "icon": "assets/icon.ico",
      "artifactName": "VANTAGE-${version}-Setup.${ext}"
    },
    "mac": {
      "target": ["dmg", "zip"],
      "icon": "assets/icon.icns",
      "category": "public.app-category.business",
      "notarize": true
    },
    "linux": {
      "target": ["AppImage", "deb", "rpm"],
      "icon": "assets/icon.png",
      "category": "VideoConference",
      "artifactName": "VANTAGE-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "vantage",
      "repo": "vantage-desktop"
    }
  },
  "keywords": [
    "electron",
    "video-conferencing",
    "live-streaming",
    "vantage"
  ],
  "author": "VANTAGE Team",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.0",
    "@types/node": "^20.10.0",
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.7"
  }
}
